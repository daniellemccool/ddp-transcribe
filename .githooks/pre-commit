#!/usr/bin/env bash
# pre-commit — fail-fast on adg validate. Per AD0020, ADR consistency is
# enforced at commit time; this is the backstop in case post-mutation validate
# (run by scripts/adr-fill and the AD0018 review protocol) was bypassed.
set -e
if [[ -d docs/decisions ]]; then
    adg --model docs/decisions validate
fi
